<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Comparateur de Karts</title>
    <style>
        body { font-family: sans-serif; background: #f0f0f0; padding: 20px; }
        .container { display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }
        .card { background: white; border-radius: 15px; padding: 20px; width: 250px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        h2 { text-align: center; color: #e74c3c; }
        .stat-bar { background: #eee; border-radius: 10px; height: 10px; margin: 10px 0; overflow: hidden; }
        .progress { background: #f1c40f; height: 100%; }
        label { font-size: 0.8em; font-weight: bold; }
    </style>
</head>
<body>
    <h1>Comparatif des 5 Karts</h1>
    <div class="container" id="app">
        <div class="card">
            <h2>Kart Rapide</h2>
            <label>Vitesse: 9/10</label>
            <div class="stat-bar"><div class="progress" style="width: 90%"></div></div>
            <label>Accélération: 4/10</label>
            <div class="stat-bar"><div class="progress" style="width: 40%"></div></div>
            <label>Poids: 3/10</label>
            <div class="stat-bar"><div class="progress" style="width: 30%"></div></div>
            <label>Maniabilité: 7/10</label>
            <div class="stat-bar"><div class="progress" style="width: 70%"></div></div>
            <label>Hors-piste: 2/10</label>
            <div class="stat-bar"><div class="progress" style="width: 20%"></div></div>
        </div>
    </div>
</body>
</html>
