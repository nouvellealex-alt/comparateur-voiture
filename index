<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KartScope | Data Analysis Platform</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        /* --- DESIGN SYSTEM (CSS) --- */
        :root {
            --bg-dark: #0f172a;
            --card-dark: #1e293b;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --accent-cyan: #0ea5e9;
            --accent-pink: #f43f5e;
            --accent-green: #10b981;
            --border-color: #334155;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            line-height: 1.6;
        }

        /* Hero Section */
        header {
            text-align: center;
            padding: 60px 20px;
            background: radial-gradient(circle at center, #1e293b 0%, #0f172a 70%);
            border-bottom: 1px solid var(--border-color);
        }

        h1 {
            font-size: 3.5rem;
            margin: 0;
            font-weight: 900;
            letter-spacing: -2px;
            background: -webkit-linear-gradient(0deg, var(--accent-cyan), var(--accent-pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .subtitle {
            color: var(--text-muted);
            font-size: 1.2rem;
            margin-top: 10px;
        }

        /* Container global */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* Section Lab (Graphique) */
        .lab-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-bottom: 60px;
        }

        .card {
            background: var(--card-dark);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .card h2 { margin-top: 0; font-size: 1.5rem; border-bottom: 2px solid var(--accent-cyan); display: inline-block; padding-bottom: 5px; }

        /* Contrôles du comparateur */
        .controls {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        select {
            background: var(--bg-dark);
            color: white;
            padding: 10px;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            width: 100%;
            font-size: 1rem;
        }

        /* Stats numériques */
        .stat-display {
            margin-top: 20px;
        }
        .stat-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .score-total {
            font-size: 2rem;
            font-weight: bold;
            color: var(--accent-green);
            text-align: right;
            margin-top: 15px;
        }

        /* Section News */
        .news-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .news-item {
            background: var(--card-dark);
            border-left: 4px solid var(--accent-pink);
            padding: 20px;
            border-radius: 8px;
        }

        .news-source {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--accent-muted);
            font-weight: bold;
            display: block;
            margin-bottom: 5px;
        }

        .news-date { color: var(--text-muted); font-size: 0.8rem; float: right; }

        footer {
            text-align: center;
            padding: 40px;
            color: var(--text-muted);
            font-size: 0.9rem;
            border-top: 1px solid var(--border-color);
            margin-top: 60px;
        }

        /* Responsive Mobile */
        @media (max-width: 768px) {
            .lab-grid { grid-template-columns: 1fr; }
            h1 { font-size: 2.5rem; }
        }
    </style>
</head>
<body>

    <header>
        <h1>KARTSCOPE</h1>
        <p class="subtitle">Data Driven Racing Intelligence • Engine Class 150cc</p>
    </header>

    <div class="container">
        
        <section>
            <h2 style="color: var(--accent-cyan);">🔬 Performance Lab</h2>
            <p style="color: var(--text-muted); margin-bottom: 30px;">
                Select two vehicles to compare their telemetry data based on our proprietary algorithm.
            </p>

            <div class="lab-grid">
                <div class="card">
                    <canvas id="radarChart"></canvas>
                </div>

                <div class="card">
                    <div class="controls">
                        <select id="selectKart1" onchange="updateChart()"></select>
                        <select id="selectKart2" onchange="updateChart()"></select>
                    </div>

                    <div id="data-panel">
                        <h3>Analysis Summary</h3>
                        <div class="stat-row">
                            <span>🚀 Speed Differential</span>
                            <span id="diff-speed" style="font-weight:bold;">0</span>
                        </div>
                        <div class="stat-row">
                            <span>⚖️ Weight / Handling Ratio</span>
                            <span id="diff-handling" style="font-weight:bold;">0</span>
                        </div>
                        <div class="stat-row">
                            <span>🏆 Meta Score (P1)</span>
                            <span id="score-p1" class="score-total">0.0</span>
                        </div>
                        <div class="stat-row">
                            <span>🏆 Meta Score (P2)</span>
                            <span id="score-p2" class="score-total" style="color:var(--accent-pink)">0.0</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section>
            <h2 style="color: var(--accent-pink);">📰 Intelligence & Sources</h2>
            <div class="news-grid">
                <div class="news-item">
                    <span class="news-source">IGN Analysis • <span class="news-date">March 2, 2026</span></span>
                    <h3>Why Speed Stats Are Overrated</h3>
                    <p style="font-size: 0.9rem; color: #cbd5e1;">
                        New data shows that acceleration and mini-turbo stats correlate 40% higher with win rates in online lobbies than pure top speed.
                    </p>
                </div>
                <div class="news-item">
                    <span class="news-source">Nintendo Press • <span class="news-date">Feb 28, 2026</span></span>
                    <h3>Upcoming Balance Patch 3.0?</h3>
                    <p style="font-size: 0.9rem; color: #cbd5e1;">
                        Rumors circulate about a nerf to the "Teddy Buggy" meta. Competitive players are already testing heavyweight alternatives.
                    </p>
                </div>
                <div class="news-item">
                    <span class="news-source">Reddit Competitive • <span class="news-date">Today</span></span>
                    <h3>The Hidden "Invincibility" Stat</h3>
                    <p style="font-size: 0.9rem; color: #cbd5e1;">
                        User data compilation reveals hidden i-frames values differ between karts. The "Standard Kart" ranks surprisingly high.
                    </p>
                </div>
            </div>
        </section>

    </div>

    <footer>
        <p>Harry Wilson Projects © 2026 • Data aggregated from public competitive sources.</p>
    </footer>

    <script>
        // 1. DATASET : Les données brutes des karts
        const karts = [
            { id: 0, name: "Standard Kart", speed: 5, accel: 5, weight: 5, handling: 5, traction: 5 },
            { id: 1, name: "Blue Falcon", speed: 8, accel: 3, weight: 4, handling: 4, traction: 3 },
            { id: 2, name: "Pipe Frame", speed: 4, accel: 8, weight: 3, handling: 9, traction: 7 },
            { id: 3, name: "Gold Standard", speed: 9, accel: 2, weight: 9, handling: 3, traction: 2 },
            { id: 4, name: "Biddybuggy (Meta)", speed: 2, accel: 10, weight: 1, handling: 10, traction: 9 }
        ];

        // 2. Initialisation des Selects
        const sel1 = document.getElementById('selectKart1');
        const sel2 = document.getElementById('selectKart2');

        karts.forEach((k, index) => {
            let opt1 = new Option(k.name, index);
            let opt2 = new Option(k.name, index);
            sel1.add(opt1);
            sel2.add(opt2);
        });

        // Sélection par défaut
        sel1.value = 0; // Standard
        sel2.value = 4; // Biddybuggy

        // 3. Calcul du "Meta Score" (Algorithme pondéré)
        function calculateScore(k) {
            // Formule : Speed(30%) + Accel(25%) + Handling(20%) + Traction(15%) + Weight(10%)
            return (
                (k.speed * 0.3) + 
                (k.accel * 0.25) + 
                (k.handling * 0.2) + 
                (k.traction * 0.15) + 
                (k.weight * 0.1)
            ).toFixed(2);
        }

        // 4. Configuration du Graphique Radar
        let radarChart;
        const ctx = document.getElementById('radarChart').getContext('2d');

        function initChart() {
            radarChart = new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: ['Speed', 'Acceleration', 'Weight', 'Handling', 'Traction'],
                    datasets: []
                },
                options: {
                    scales: {
                        r: {
                            angleLines: { color: 'rgba(255, 255, 255, 0.2)' },
                            grid: { color: 'rgba(255, 255, 255, 0.2)' },
                            pointLabels: { color: '#cbd5e1', font: {size: 12} },
                            suggestedMin: 0,
                            suggestedMax: 10,
                            ticks: { display: false } // Cache les nombres sur l'axe
                        }
                    },
                    plugins: {
                        legend: { labels: { color: 'white' } }
                    }
                }
            });
            updateChart();
        }

        // 5. Fonction de mise à jour (Appelée quand on change un select)
        function updateChart() {
            const k1 = karts[sel1.value];
            const k2 = karts[sel2.value];

            // Mise à jour des données du graphique
            radarChart.data.datasets = [
                {
                    label: k1.name,
                    data: [k1.speed, k1.accel, k1.weight, k1.handling, k1.traction],
                    backgroundColor: 'rgba(14, 165, 233, 0.4)', // Bleu
                    borderColor: '#0ea5e9',
                    borderWidth: 2
                },
                {
                    label: k2.name,
                    data: [k2.speed, k2.accel, k2.weight, k2.handling, k2.traction],
                    backgroundColor: 'rgba(244, 63, 94, 0.4)', // Rose
                    borderColor: '#f43f5e',
                    borderWidth: 2
                }
            ];
            radarChart.update();

            // Mise à jour des chiffres texte
            document.getElementById('score-p1').innerText = calculateScore(k1);
            document.getElementById('score-p2').innerText = calculateScore(k2);
            
            // Calcul différentiel simple
            let speedDiff = (k1.speed - k2.speed).toFixed(1);
            let diffElem = document.getElementById('diff-speed');
            diffElem.innerText = speedDiff > 0 ? `+${speedDiff} (Blue)` : `${speedDiff} (Pink)`;
            diffElem.style.color = speedDiff > 0 ? '#0ea5e9' : '#f43f5e';
        }

        // Démarrage
        initChart();

    </script>
</body>
</html>
